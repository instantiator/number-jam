{
  "name": "number-jam",
  "version": "0.1.0",
  "description": "Detect, track, and optionally pixelate number plates in video files.",
  "main": "dist/cli.js",
  "bin": {
    "number-jam": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --project tsconfig.test.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "download-fixtures": "tsx scripts/download-fixtures.ts",
    "generate-formats": "tsx scripts/generate-formats.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "sharp": "^0.33.5",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
