{
  "name": "number-jam",
  "version": "1.0.0",
  "description": "Detect, track, and optionally pixelate number plates in video files.",
  "repository": {
    "type": "git",
    "url": "https://github.com/instantiator/number-jam"
  },
  "main": "dist/cli.js",
  "bin": {
    "number-jam": "dist/cli.js"
  },
  "files": [
    "dist/",
    "docker/"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc",
    "typecheck": "tsc --project tsconfig.test.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "download-fixtures": "tsx scripts/download-fixtures.ts",
    "generate-formats": "tsx scripts/generate-formats.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "p-limit": "^7.3.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
